# В КОРНЕ проекта (рядом с server.js) можно использовать `.env` и/или `post.env` (см. lib/load-env.mjs).
# Сначала читается `.env`, потом `post.env` (переопределяет ключи) — удобно хранить секреты в `post.env`.
# Эти файлы не коммитьте.
# Загрузка не зависит от папки, из которой вы запустили `node server.js`.

# Локально можно не задавать — сервер возьмёт встроенный dev-секрет (в консоли будет предупреждение).
# В production обязательно: случайная строка не короче 32 символов.
# JWT_SECRET=
# Срок жизни JWT (по умолчанию): admin 7d, остальные 30d.
# JWT_EXPIRES_IN_ADMIN=7d
# JWT_EXPIRES_IN_USER=30d

# Список разрешённых Origin для браузерных запросов к API (через запятую, без пробелов или с пробелами — обрежутся).
# Нужно только при NODE_ENV=production. Пример:
# ALLOWED_ORIGINS=https://shop.example.com,https://www.example.com

# За обратным прокси (Nginx, Cloudflare) включите, чтобы rate limit и IP определялись верно:
# TRUST_PROXY=1

# NODE_ENV=production
# PORT=3000
# CRM_WEBHOOK_URL=
# В production действует усиленная парольная политика (минимум 10 символов, буквы + цифры).

# --- CRM (пользователи + заявки) ---
# Без DATABASE_URL данные в файле crm-db.json (как раньше). Удобно править сайт/админку/CRM локально.
# С DATABASE_URL тот же JSON-объект хранится в PostgreSQL, таблица crm_state (одна строка JSONB).
# Локальный Postgres: npm run docker:up, затем:
# DATABASE_URL=postgresql://dp:dp_local_dev@localhost:5432/coatings
# Первый импорт из файла: npm run crm:import-json
# DATABASE_URL=
# Для Cloud SQL / Neon часто нужен SSL:
# PGSSLMODE=require
# При самоподписанном сертификате (только если провайдер требует): PGSSL_REJECT_UNAUTHORIZED=0

# --- LiqPay (UA) — онлайн-оплата карткою; keys з кабінету https://www.liqpay.ua/
# LIQPAY_PUBLIC_KEY=
# LIQPAY_PRIVATE_KEY=
# Тестовий режим (1 = sandbox):
# LIQPAY_SANDBOX=1
# Публічна URL сервера для result_url / server_url (обов’язково в production за проксі):
# PUBLIC_BASE_URL=https://ваш-домен.ua

# --- Транзакційна пошта (Gmail SMTP + App Password) ---
# Увімкніть двоетапну перевірку Google → «Паролі додатків» → згенеруйте 16 символів.
# Не використовуйте основний пароль від пошти в коді — тільки App Password.
# SMTP_USER=reaxondh@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# smtp.gmail.com, порт 465 (SSL) — значення за замовчуванням у lib/transactional-mail.mjs
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=1
# Автоматичне надсилання: після створення заявки сервер надсилає лист адміністратору (MAIL_ADMIN_TO) та підтвердження клієнту на email із заявки — без ручної відправки з CRM.
# Для оформлення юрособою (checkout): якщо окремий email для рахунків — йому також автоматично надходить копія з корзиною й реквізитами.
# Від кого показується лист (опційно):
# MAIL_FROM=Reaxon <reaxondh@gmail.com>
# Куди слати сповіщення про нові заявки (за замовчуванням = SMTP_USER):
# MAIL_ADMIN_TO=reaxondh@gmail.com
# Швидкі заявки з банерів (контакти «Заказать звонок», головна «Получить расчёт»; за замовчуванням reaxondh@gmail.com; перекриває MAIL_ADMIN_TO):
# CALLBACK_BANNER_EMAIL=
# Додаткова прихована копія (опційно):
# MAIL_BCC=

# --- Telegram: дублікати заявок з банерів («Заказать звонок», «Получить расчёт») у канал для менеджерів ---
# Посилання запрошення (наприклад https://t.me/+yvLoV4wnuARkNjIy) саме по собі не є chat_id — його потрібно отримати окремо.
# 1) @BotFather → створити бота → TELEGRAM_BOT_TOKEN
# 2) Додати бота адміністратором каналу з правом «Публікувати повідомлення»
# 3) Узгодити TELEGRAM_BANNER_NOTIFY_CHAT_ID (часто -100xxxxxxxxxx для каналу; для публічного каналу іноді @username)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BANNER_NOTIFY_CHAT_ID=
# Публічна URL сайту для посилань у листах (ЛК, повідомлення менеджера). Без слеша в кінці.
# Локально: http://localhost:3000
# PUBLIC_SITE_URL=https://ваш-домен.ua

# --- Нова пошта (довідник міст / відділень на сторінці оформлення) ---
# Ключ із кабінету https://novaposhta.ua/ → API → ключ (на сервері, не в браузері).
# NOVAPOSHTA_API_KEY=
